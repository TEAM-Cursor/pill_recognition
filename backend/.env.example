# backend/.env.example — 키 "이름"만 적는 템플릿. 실제 값은 backend/.env 에 넣는다(절대 커밋 금지).
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채운다.
#   Windows:  copy .env.example .env
#   mac/Linux: cp .env.example .env

# Claude (Anthropic) API 키 — https://console.anthropic.com
ANTHROPIC_API_KEY=

# 공공데이터포털 인증키 (낱알식별·DUR·e약은요) — https://www.data.go.kr
# 한 계정 키로 여러 API를 활성화해 쓰는 경우 이 키 하나. API별 키가 따로 발급되면 분리해서 추가.
DATA_GO_KR_KEY=
